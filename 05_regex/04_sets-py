import re

# [] -> coincide con cualquier caracter dentro de los corchetes
username = "rub.ius$_69+"
pattern = r"^[\w._%+-]+$" # debe cumplirse de principio a fin en la cadena
match = re.search(pattern, username)
if match: print("Usuario válido")
else: print("Usuario no válido")

# Buscar todas las vocales de una palabra
text = "hola mundo"
pattern = r"[aeiou]"
matches = re.findall(pattern, text)
print(matches)

# Una Regex para encontrar las palabras man, fan y ban
# pero ignora el resto
text = "man fan ban ñan ran"
pattern = r"[mfb]an" # el caracter del principio puede ser m, f o b
matches = re.findall(pattern, text)
print(matches)

# Ejercicio:
# Ahora hay palabras que encajan pero no empiezan por esas letras.
# Solo queremos las palabras man, fan y ban
text = "omniman fanatico man bandana"
pattern = r"\b[mfb]an\b"
matches = re.findall(pattern, text)
print(matches)

# [^]: Coincide con cualquier caracter que no esté dentro de los corchetes
text = "Hola mundo"
pattern = r"[^aeiou]"
matches = re.findall(pattern, text)
print(matches)

